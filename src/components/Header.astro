---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import { translations } from '../i18n/translations';
const t = translations;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header>
	<nav>
		<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={`${base}/`} data-i18n="home">ホーム</HeaderLink>
			<HeaderLink href={`${base}/blog`} data-i18n="blog">ブログ</HeaderLink>
			<HeaderLink href={`${base}/about`} data-i18n="about">このサイトについて</HeaderLink>
			<button id="lang-toggle" class="lang-btn" aria-label="Switch language">
				<span data-i18n="langToggle">English</span>
			</button>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--accent);
		font-weight: 700;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--gray-dark));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	nav a:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.lang-btn {
		background: none;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		padding: 0.3em 0.8em;
		cursor: pointer;
		font-size: 0.9em;
		color: rgb(var(--gray-dark));
		margin-left: 0.5em;
		transition: border-color 0.2s, color 0.2s;
	}
	.lang-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
</style>
<script>
	import { translations } from '../i18n/translations';

	function applyLang(lang: string) {
		const t = translations[lang as keyof typeof translations];
		document.querySelectorAll('[data-i18n]').forEach((el) => {
			const key = (el as HTMLElement).dataset.i18n as keyof typeof t;
			if (t[key] !== undefined) {
				el.textContent = t[key];
			}
		});
		document.documentElement.lang = lang;
		localStorage.setItem('lang', lang);
	}

	function toggleLang() {
		const current = localStorage.getItem('lang') || 'ja';
		const next = current === 'ja' ? 'en' : 'ja';
		applyLang(next);
	}

	// Apply saved language on page load
	const saved = localStorage.getItem('lang') || 'ja';
	applyLang(saved);

	document.getElementById('lang-toggle')?.addEventListener('click', toggleLang);
</script>
